<main class="flex h-screen w-screen overflow-hidden bg-base-100 text-base-content font-sans antialiased text-[15px] selection:bg-primary/30">
  <div class="flex-1 flex flex-col min-w-0 bg-base-100 relative overflow-y-auto">
    <.flash_group flash={@flash} />
    {render_slot(@inner_block)}
  </div>
</main>
